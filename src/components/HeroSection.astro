---
/**
 * HeroSection.astro – Landing hero area
 *
 * Shadcn integration notes:
 * - "Explore Collections" and "Our Story" buttons are candidates for
 *   <Button variant="default"> and <Button variant="outline"> respectively.
 *   The gradient button keeps a custom class; the outline button maps cleanly.
 */
---

<section class="max-w-7xl mx-auto px-4 sm:px-8 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center" aria-label="Hero">
  <!-- Copy -->
  <div class="space-y-8 order-2 lg:order-1">
    <span
      class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-bold tracking-widest uppercase"
    >
      Artisanal Excellence
    </span>

    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-headline font-bold text-on-surface leading-[1.1] tracking-tight"
    >
      Purest Ingredients, <br /><span class="text-md-primary italic"
        >Purest Love.</span
      >
    </h1>

    <p class="text-lg text-on-surface-variant max-w-lg leading-relaxed">
      Crafting memories through the delicate art of traditional baking. Every
      cookie is a hand-shaped masterpiece using premium European butter and
      local heritage recipes.
    </p>

    <!-- CTA group -->
    <div class="flex flex-wrap gap-4 pt-4">
      <a
        href="#menu"
        class="rose-gold-gradient text-on-primary px-10 py-4 rounded-full font-bold text-lg shadow-xl hover:opacity-90 transition-all inline-block"
      >
        Explore Collections
      </a>
      <a
        href="#story"
        class="px-10 py-4 rounded-full font-bold text-lg text-md-primary border border-outline-variant/30 hover:bg-surface-container transition-all inline-block"
      >
        Our Story
      </a>
    </div>
  </div>

  <!-- Hero image cluster -->
  <div class="relative order-1 lg:order-2">
    <div
      class="aspect-square rounded-xl overflow-hidden shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-700 bg-surface-container-high"
    >
      <img
        class="w-full h-full object-cover"
        alt="Top-down flat lay of aesthetically arranged premium butter cookies on a light marble surface with dried flower petals and silk ribbon"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuA86CyUtm2dNshnN9z71A3Os-NSzmo07Luv1qmDQo8xDa-APREU-n8Z3FjOc9ZluPEqWL6z3kRSbVIUccwutOAay-BfmZy1SOJgeoI0e3RmhHHYDyRd0t8WjWm9wKEjAHTZVtpIb3rfZRoHh358qBGVnZnD2grXcwF1dmB-feoqKmPhN8h41imifB_HafgZTKN0V5Q5LHXZilJQxfzjcC2jOfmo1scSID7WlMxIZT3a1Cf9gVU2a1mXaS_F4H9THsTUOxyQLPbNxKY"
        width="600"
        height="600"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div
      class="absolute -bottom-10 -left-10 w-48 h-48 rounded-xl overflow-hidden border-8 border-surface shadow-xl hidden md:block"
    >
      <img
        class="w-full h-full object-cover"
        alt="Close-up of a single artisan cookie being dipped in milk with soft morning sunlight streaming through a window"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBoD_j60ZtQUSDNWsumnO14p5DmAWhL7peKCsXYK1e0uOZ-YXvPe4_0Kb60o-y-gZhvJGAIzSCcI-i5_leu509ZOK6Rh9nDFN_ckwaJu6HjSMeU423ubecWNCDXbT3pvK27qjJZSEEZW52pgoJcBmqen0FgyMNUB3hmhiRVOE5io1SR54X11_uljdo6-ulMWEhaSPqDvlYMSQ61SbhXKnKppzVDx5bsx0ZgLVWum42ozeKbdlFGY3ZO8Fw7_PtpEiPqgGDNJiqnwwc"
        width="192"
        height="192"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
