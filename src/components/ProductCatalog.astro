---
/**
 * ProductCatalog.astro – Bento-grid product showcase
 *
 * Shadcn integration notes:
 * - Each product tile is a candidate for <Card> / <CardHeader> / <CardContent>.
 *   The current markup uses custom rounded-xl containers that can be swapped to:
 *     <Card className="group relative overflow-hidden …">
 *       <CardHeader>…title + badge…</CardHeader>
 *       <CardContent>…image…</CardContent>
 *     </Card>
 * - "Details" and "Order Now" CTAs can use <Button variant="outline" size="sm">.
 */

interface Product {
  name: string;
  tagline: string;
  image: string;
  alt: string;
  badge?: string;
  featured?: boolean;
}

const products: Product[] = [
  {
    name: "Nastar Royale",
    tagline: "Handmade pineapple jam encased in a melt-in-your-mouth golden crust.",
    image: "/vanrezbake-lp/images/image_catalog_section_featured.webp",
    alt: "Golden brown spherical nastar pineapple cookies arranged in a decorative bowl",
    badge: "Bestseller",
    featured: true,
  },
  {
    name: "Kastengel",
    tagline: "Aged Edam & Cheddar crunch.",
    image: "/vanrezbake-lp/images/image_catalog_section_1.webp",
    alt: "Long rectangular cheese cookies topped with grated cheddar cheese on a ceramic plate",
  },
  {
    name: "Putri Salju",
    tagline: "Cooling sugar-dusted crescents.",
    image: "/vanrezbake-lp/images/image_catalog_section_2.webp",
    alt: "Crescent shaped cookies covered in white powdered sugar on a wooden tray",
  },
  {
    name: "Sagu Keju",
    tagline: "Light, airy cheese blossoms.",
    image: "/vanrezbake-lp/images/image_catalog_section_3.webp",
    alt: "Delicate spiral shaped cheese cookies made from sago flour on a pastel background",
  },
  {
    name: "Peanut Bliss",
    tagline: "Traditional roasted peanut nutty heart.",
    image: "/vanrezbake-lp/images/image_catalog_section_4.webp",
    alt: "Round roasted peanut cookies with a glazed finish and a whole nut on top",
  },
];
---

<section class="max-w-7xl mx-auto px-4 sm:px-8 py-16" id="menu" aria-labelledby="menu-heading">
  <!-- Section header -->
  <div class="text-center mb-16 space-y-4">
    <h2 id="menu-heading" class="text-4xl font-headline font-bold">The Signature Collection</h2>
    <p class="text-on-surface-variant">Hand-picked favorites that define the Vanrez standard.</p>
  </div>

  <!-- Bento grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {products.map((product) =>
      product.featured ? (
        <!-- Featured product (Nastar) – large tile -->
        <div class="md:col-span-2 md:row-span-2 group relative overflow-hidden rounded-xl bg-surface-container-low p-6 transition-all hover:bg-surface-container min-h-[260px] sm:min-h-[380px]">
          <div class="relative z-10 space-y-2 mb-4">
            {product.badge && (
              <span class="text-md-secondary font-bold text-xs tracking-widest uppercase">
                {product.badge}
              </span>
            )}
            <h3 class="text-3xl font-headline font-bold">{product.name}</h3>
            <p class="text-on-surface-variant max-w-xs">{product.tagline}</p>
          </div>
          <div class="absolute bottom-0 right-0 w-3/4 h-3/4 transform translate-y-10 translate-x-10 group-hover:translate-y-0 group-hover:translate-x-0 transition-transform duration-500 rounded-lg overflow-hidden">
            <img
              class="w-full h-full object-contain"
              alt={product.alt}
              src={product.image}
              width="400"
              height="400"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="absolute bottom-6 left-6">
            <button type="button" aria-label={`Order ${product.name}`} class="inline-flex items-center gap-2 bg-surface-container-lowest px-4 py-2 rounded-full text-sm font-bold shadow-sm hover:bg-surface-container-high transition-colors cursor-pointer">
              Order Now <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span>
            </button>
          </div>
        </div>
      ) : (
        <!-- Standard product tile – candidate for <Card> -->
        <div class="group relative overflow-hidden rounded-xl bg-surface-container-high p-6 transition-all">
          <h3 class="text-xl font-headline font-bold mb-1">{product.name}</h3>
          <p class="text-sm text-on-surface-variant mb-4">{product.tagline}</p>
          <div class="aspect-square rounded-lg overflow-hidden mb-4">
            <img
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              alt={product.alt}
              src={product.image}
              width="400"
              height="400"
              loading="lazy"
              decoding="async"
            />
          </div>
          {/* Wire to product detail page when routing exists; for now scrolls to menu section */}
          <a
            href="#menu-heading"
            aria-label={`View details for ${product.name}`}
            class="block w-full py-2 rounded-full border border-md-primary text-md-primary font-bold text-xs uppercase tracking-tighter text-center hover:bg-md-primary hover:text-on-primary transition-colors"
          >
            Details
          </a>
        </div>
      )
    )}
  </div>
</section>
